# Copy this file to .env and fill in your actual API keys

# Example for keys
NANOGPT_API_KEY=your_key_here


MINIMAX_API_KEY=your_key_here

# Optional admin password for protected model changes
# YALLMP_ADMIN_PASSWORD=your_admin_password

# GigaChat credentials (only needed if you configure GigaChat models)
# GIGACHAT_API_KEY=your_base64_encoded_key
# GIGACHAT_SCOPE=GIGACHAT_API_CORP
# GIGACHAT_CLIENT_CERT=path/to/cert.pem
# GIGACHAT_CLIENT_KEY=path/to/key.pem
